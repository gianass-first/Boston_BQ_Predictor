cat > .gitignore << 'EOF'
# Data - ignorar contenidos pero permitir .gitkeep
data/raw/*
data/processed/*
data/train/*
data/test/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/train/.gitkeep
!data/test/.gitkeep

# Modelos serializados y métricas generadas pero mantener estructura
models/*.pkl
models/*.joblib
models/*.csv
!models/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.ipynb_checkpoints/

# Notebooks ejecutados
*_executed.ipynb

# IDE
.vscode/
.idea/
.DS_Store

# Streamlit
.streamlit/secrets.toml
EOF
